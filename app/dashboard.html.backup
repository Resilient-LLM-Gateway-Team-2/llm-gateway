<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Resilient LLM Gateway</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-color: #0a0a0f;
            --panel-bg: #12121a;
            --card-bg: #1a1a28;
            --border-color: rgba(255,255,255,0.06);
            --border-hover: rgba(255,255,255,0.12);
            --text-main: #e8e8f0;
            --text-muted: #6b6b80;
            --text-dim: #45455a;
            --accent: #a78bfa;
            --accent-glow: rgba(167,139,250,0.15);
            --user-msg: #6d28d9;
            --user-msg-hover: #7c3aed;
            --bot-msg: #1e1e2e;
            --success: #34d399;
            --success-dim: rgba(52,211,153,0.12);
            --warning: #fbbf24;
            --warning-dim: rgba(251,191,36,0.12);
            --error: #f87171;
            --error-dim: rgba(248,113,113,0.12);
            --openai-color: #10a37f;
            --gemini-color: #8ab4f8;
            --mock-color: #f87171;
            --cache-color: #34d399;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            display: flex;
            flex-direction: column;
            height: 100vh;
            overflow: hidden;
        }

        /* ═══════════ TOP NAV BAR ═══════════ */
        .top-bar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 24px;
            background: linear-gradient(180deg, rgba(18,18,26,0.98) 0%, rgba(18,18,26,0.92) 100%);
            border-bottom: 1px solid var(--border-color);
            backdrop-filter: blur(20px);
            z-index: 10;
            flex-shrink: 0;
        }

        .top-bar-left {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .logo-icon {
            width: 32px;
            height: 32px;
            background: linear-gradient(135deg, var(--accent), #6d28d9);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            font-weight: 700;
            color: white;
            box-shadow: 0 2px 12px var(--accent-glow);
        }

        .top-bar h1 {
            font-size: 1.05rem;
            font-weight: 600;
            letter-spacing: -0.01em;
            color: var(--text-main);
        }

        .top-bar h1 span {
            color: var(--accent);
        }

        .top-bar-right {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .health-indicators {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .health-dot {
            display: flex;
            align-items: center;
            gap: 5px;
            font-size: 0.72rem;
            font-weight: 500;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .health-dot .dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background-color: var(--text-dim);
            transition: background-color 0.5s, box-shadow 0.5s;
        }

        .health-dot .dot.ok {
            background-color: var(--success);
            box-shadow: 0 0 6px rgba(52,211,153,0.5);
        }

        .health-dot .dot.err {
            background-color: var(--error);
            box-shadow: 0 0 6px rgba(248,113,113,0.5);
        }

        .api-key-input {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            color: var(--text-main);
            padding: 7px 14px;
            border-radius: 8px;
            font-size: 0.82rem;
            font-family: inherit;
            width: 220px;
            outline: none;
            transition: border-color 0.25s, box-shadow 0.25s;
        }

        .api-key-input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px var(--accent-glow);
        }

        /* ═══════════ SESSION STATS BAR ═══════════ */
        .stats-bar {
            display: flex;
            align-items: center;
            gap: 0;
            padding: 0 24px;
            background: var(--panel-bg);
            border-bottom: 1px solid var(--border-color);
            flex-shrink: 0;
            height: 44px;
        }

        .stat-item {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 0 20px;
            height: 100%;
            border-right: 1px solid var(--border-color);
            font-size: 0.78rem;
        }

        .stat-item:last-child { border-right: none; }

        .stat-label {
            color: var(--text-muted);
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            font-size: 0.68rem;
        }

        .stat-value {
            font-weight: 600;
            color: var(--text-main);
            font-variant-numeric: tabular-nums;
        }

        .stat-value.accent { color: var(--accent); }
        .stat-value.success { color: var(--success); }

        /* ═══════════ MAIN LAYOUT ═══════════ */
        .main-layout {
            display: flex;
            flex: 1;
            overflow: hidden;
        }

        /* ═══════════ CHAT PANEL ═══════════ */
        .chat-panel {
            flex: 1;
            display: flex;
            flex-direction: column;
            border-right: 1px solid var(--border-color);
            min-width: 0;
        }

        .messages {
            flex: 1;
            padding: 24px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 14px;
        }

        .message {
            max-width: 75%;
            padding: 12px 18px;
            border-radius: 16px;
            line-height: 1.6;
            font-size: 0.92rem;
            animation: msgIn 0.35s cubic-bezier(0.16, 1, 0.3, 1);
        }

        @keyframes msgIn {
            from { opacity: 0; transform: translateY(12px) scale(0.97); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }

        .user-message {
            align-self: flex-end;
            background: linear-gradient(135deg, var(--user-msg), var(--user-msg-hover));
            color: white;
            border-bottom-right-radius: 4px;
        }

        .bot-message {
            align-self: flex-start;
            background-color: var(--bot-msg);
            border: 1px solid var(--border-color);
            border-bottom-left-radius: 4px;
        }

        .bot-message.error-msg {
            border-color: rgba(248,113,113,0.3);
            background: rgba(248,113,113,0.06);
        }

        .input-area {
            padding: 18px 24px;
            background-color: var(--panel-bg);
            border-top: 1px solid var(--border-color);
            display: flex;
            gap: 10px;
        }

        .chat-input {
            flex: 1;
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            color: var(--text-main);
            padding: 13px 18px;
            border-radius: 12px;
            font-size: 0.95rem;
            font-family: inherit;
            outline: none;
            transition: border-color 0.25s, box-shadow 0.25s;
        }

        .chat-input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px var(--accent-glow);
        }

        .btn {
            border: none;
            padding: 0 22px;
            border-radius: 12px;
            font-weight: 600;
            font-family: inherit;
            font-size: 0.88rem;
            cursor: pointer;
            transition: all 0.2s;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--accent), #8b5cf6);
            color: white;
            box-shadow: 0 2px 12px var(--accent-glow);
        }

        .btn-primary:hover { opacity: 0.9; transform: translateY(-1px); }
        .btn-primary:active { transform: scale(0.98) translateY(0); }
        .btn-primary:disabled {
            background: #333;
            color: #666;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }

        .btn-ghost {
            background: transparent;
            color: var(--text-muted);
            border: 1px solid var(--border-color);
            padding: 0 16px;
        }

        .btn-ghost:hover {
            color: var(--text-main);
            border-color: var(--border-hover);
            background: rgba(255,255,255,0.03);
        }

        /* ═══════════ OBSERVABILITY PANEL ═══════════ */
        .obs-panel {
            width: 380px;
            background-color: var(--panel-bg);
            display: flex;
            flex-direction: column;
            flex-shrink: 0;
        }

        .obs-header {
            padding: 16px 20px;
            border-bottom: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .obs-header h2 {
            font-size: 0.82rem;
            font-weight: 600;
            color: var(--text-muted);
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .obs-tabs {
            display: flex;
            gap: 0;
            border-bottom: 1px solid var(--border-color);
        }

        .obs-tab {
            flex: 1;
            padding: 10px;
            text-align: center;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--text-muted);
            cursor: pointer;
            border-bottom: 2px solid transparent;
            transition: all 0.2s;
            background: none;
            border-top: none;
            border-left: none;
            border-right: none;
            font-family: inherit;
        }

        .obs-tab:hover { color: var(--text-main); }
        .obs-tab.active {
            color: var(--accent);
            border-bottom-color: var(--accent);
        }

        .obs-content {
            flex: 1;
            overflow-y: auto;
            padding: 16px;
        }

        .tab-panel { display: none; }
        .tab-panel.active { display: block; }

        /* Latest Metrics */
        .metrics-grid {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .metric-card {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 10px;
            padding: 14px 16px;
            display: flex;
            flex-direction: column;
            gap: 6px;
            transition: border-color 0.2s;
        }

        .metric-card:hover { border-color: var(--border-hover); }

        .metric-label {
            font-size: 0.7rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            font-weight: 500;
        }

        .metric-value {
            font-size: 1.3rem;
            font-weight: 700;
            color: var(--text-main);
            font-variant-numeric: tabular-nums;
        }

        .provider-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .provider-openai { background: rgba(16,163,127,0.12); color: var(--openai-color); border: 1px solid rgba(16,163,127,0.3); }
        .provider-gemini { background: rgba(138,180,248,0.12); color: var(--gemini-color); border: 1px solid rgba(138,180,248,0.3); }
        .provider-mock { background: rgba(248,113,113,0.12); color: var(--mock-color); border: 1px solid rgba(248,113,113,0.3); }
        .provider-cache { background: rgba(52,211,153,0.12); color: var(--cache-color); border: 1px solid rgba(52,211,153,0.3); }

        .latency-fast { color: var(--success); }
        .latency-medium { color: var(--warning); }
        .latency-slow { color: var(--error); }

        /* Request History */
        .history-list {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .history-item {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            align-items: center;
            padding: 12px;
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            font-size: 0.78rem;
            animation: msgIn 0.3s ease;
        }

        .history-time {
            color: var(--text-muted);
            font-variant-numeric: tabular-nums;
            font-size: 0.72rem;
            min-width: 60px;
        }

        .history-provider {
            font-weight: 600;
            font-size: 0.72rem;
        }

        .history-latency {
            font-weight: 600;
            font-variant-numeric: tabular-nums;
            font-size: 0.76rem;
            min-width: 60px;
        }

        .history-tokens {
            color: var(--text-muted);
            font-variant-numeric: tabular-nums;
            font-size: 0.72rem;
            min-width: 50px;
        }

        .history-empty {
            text-align: center;
            color: var(--text-dim);
            padding: 40px 20px;
            font-size: 0.85rem;
        }

        /* Loading */
        .loading-dots {
            display: none;
            align-self: flex-start;
        }

        .loading-dots .message {
            display: flex;
            gap: 4px;
            padding: 16px 20px;
        }

        .bounce-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background-color: var(--text-muted);
            animation: bounce 1.4s infinite ease-in-out both;
        }

        .bounce-dot:nth-child(1) { animation-delay: -0.32s; }
        .bounce-dot:nth-child(2) { animation-delay: -0.16s; }

        @keyframes bounce {
            0%, 80%, 100% { transform: scale(0); }
            40% { transform: scale(1); }
        }

        /* Scrollbars */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.08); border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.14); }

        /* Placeholder state */
        .empty-state {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100%;
            gap: 8px;
            color: var(--text-dim);
            font-size: 0.85rem;
        }

        .empty-state-icon {
            font-size: 2rem;
            margin-bottom: 4px;
        }
    </style>
</head>
<body>

    <!-- ═══════════ TOP NAV BAR ═══════════ -->
    <header class="top-bar">
        <div class="top-bar-left">
            <div class="logo-icon">⚡</div>
            <h1>Resilient <span>LLM Gateway</span></h1>
        </div>
        <div class="top-bar-right">
            <div class="health-indicators" id="healthIndicators">
                <div class="health-dot"><span class="dot" id="healthApi"></span> API</div>
                <div class="health-dot"><span class="dot" id="healthPostgres"></span> Postgres</div>
                <div class="health-dot"><span class="dot" id="healthRedis"></span> Redis</div>
            </div>
            <input type="password" id="apiKey" class="api-key-input"
                   placeholder="Enter X-API-Key" value="test_key">
        </div>
    </header>

    <!-- ═══════════ SESSION STATS BAR ═══════════ -->
    <div class="stats-bar" id="statsBar">
        <div class="stat-item">
            <span class="stat-label">Requests</span>
            <span class="stat-value accent" id="statRequests">0</span>
        </div>
        <div class="stat-item">
            <span class="stat-label">Avg Latency</span>
            <span class="stat-value" id="statAvgLatency">— ms</span>
        </div>
        <div class="stat-item">
            <span class="stat-label">Total Tokens</span>
            <span class="stat-value" id="statTotalTokens">0</span>
        </div>
        <div class="stat-item">
            <span class="stat-label">Cache Hits</span>
            <span class="stat-value success" id="statCacheHits">0%</span>
        </div>
    </div>

    <!-- ═══════════ MAIN LAYOUT ═══════════ -->
    <div class="main-layout">
        <!-- CHAT PANEL -->
        <div class="chat-panel">
            <div class="messages" id="chatBox">
                <div class="message bot-message">
                    Welcome to the Resilient LLM Gateway. Type a message to test automatic provider routing and failover. The gateway will try OpenAI → Gemini → Mock automatically.
                </div>
            </div>

            <div class="loading-dots" id="loadingIndicator">
                <div class="message bot-message">
                    <span class="bounce-dot"></span>
                    <span class="bounce-dot"></span>
                    <span class="bounce-dot"></span>
                </div>
            </div>

            <div class="input-area">
                <input type="text" id="messageInput" class="chat-input"
                       placeholder="Type a message and let the gateway route it..."
                       autocomplete="off">
                <button id="clearBtn" class="btn btn-ghost" onclick="clearChat()">Clear</button>
                <button id="sendBtn" class="btn btn-primary" onclick="sendMessage()">Send</button>
            </div>
        </div>

        <!-- OBSERVABILITY PANEL -->
        <aside class="obs-panel">
            <div class="obs-header">
                <h2>Observability</h2>
            </div>
            <div class="obs-tabs">
                <button class="obs-tab active" onclick="switchTab('latest')">Latest</button>
                <button class="obs-tab" onclick="switchTab('history')">History</button>
            </div>
            <div class="obs-content">
                <!-- Latest Tab -->
                <div class="tab-panel active" id="tabLatest">
                    <div class="empty-state" id="metricsEmpty">
                        <div class="empty-state-icon">📊</div>
                        <p>Send a message to view<br/>live gateway metrics</p>
                    </div>
                    <div class="metrics-grid" id="metricsGrid" style="display:none;"></div>
                </div>
                <!-- History Tab -->
                <div class="tab-panel" id="tabHistory">
                    <div class="history-list" id="historyList">
                        <div class="history-empty">No requests yet</div>
                    </div>
                </div>
            </div>
        </aside>
    </div>

    <script>
        // ═══════════ DOM REFS ═══════════
        const chatBox = document.getElementById('chatBox');
        const messageInput = document.getElementById('messageInput');
        const apiKeyInput = document.getElementById('apiKey');
        const sendBtn = document.getElementById('sendBtn');
        const loadingIndicator = document.getElementById('loadingIndicator');
        const metricsGrid = document.getElementById('metricsGrid');
        const metricsEmpty = document.getElementById('metricsEmpty');
        const historyList = document.getElementById('historyList');

        // ═══════════ SESSION STATE ═══════════
        let chatHistory = [];
        let sessionStats = {
            totalRequests: 0,
            totalLatency: 0,
            totalTokens: 0,
            cacheHits: 0,
            history: []
        };

        // ═══════════ KEYBOARD HANDLER ═══════════
        messageInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendMessage();
            }
        });

        // ═══════════ HEALTH CHECK ═══════════
        async function checkHealth() {
            try {
                const r = await fetch('/health/detailed');
                const data = await r.json();
                setHealthDot('healthApi', data.api === 'ok');
                setHealthDot('healthPostgres', data.postgres === 'ok');
                setHealthDot('healthRedis', data.redis === 'ok');
            } catch {
                setHealthDot('healthApi', false);
                setHealthDot('healthPostgres', false);
                setHealthDot('healthRedis', false);
            }
        }

        function setHealthDot(id, ok) {
            const dot = document.getElementById(id);
            dot.className = 'dot ' + (ok ? 'ok' : 'err');
        }

        // Poll health every 15s
        checkHealth();
        setInterval(checkHealth, 15000);

        // ═══════════ TAB SWITCHING ═══════════
        function switchTab(tab) {
            document.querySelectorAll('.obs-tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));

            if (tab === 'latest') {
                document.querySelectorAll('.obs-tab')[0].classList.add('active');
                document.getElementById('tabLatest').classList.add('active');
            } else {
                document.querySelectorAll('.obs-tab')[1].classList.add('active');
                document.getElementById('tabHistory').classList.add('active');
            }
        }

        // ═══════════ UPDATE SESSION STATS ═══════════
        function updateSessionStats(latency, tokens, provider) {
            sessionStats.totalRequests++;
            sessionStats.totalLatency += latency;
            sessionStats.totalTokens += tokens;
            if (provider && provider.includes('cache')) sessionStats.cacheHits++;

            const avg = Math.round(sessionStats.totalLatency / sessionStats.totalRequests);
            const cacheRate = sessionStats.totalRequests > 0
                ? Math.round((sessionStats.cacheHits / sessionStats.totalRequests) * 100)
                : 0;

            document.getElementById('statRequests').textContent = sessionStats.totalRequests;
            document.getElementById('statTotalTokens').textContent = sessionStats.totalTokens.toLocaleString();
            document.getElementById('statCacheHits').textContent = cacheRate + '%';

            const avgEl = document.getElementById('statAvgLatency');
            avgEl.textContent = avg + ' ms';
            avgEl.className = 'stat-value ' + getLatencyClass(avg);
        }

        function getLatencyClass(ms) {
            if (ms <= 2000) return 'latency-fast';
            if (ms <= 5000) return 'latency-medium';
            return 'latency-slow';
        }

        // ═══════════ CHAT HELPERS ═══════════
        function appendMessage(role, content, isError) {
            const div = document.createElement('div');
            let classes = `message ${role}-message`;
            if (isError) classes += ' error-msg';
            div.className = classes;
            div.textContent = content;
            chatBox.appendChild(div);
            chatBox.scrollTop = chatBox.scrollHeight;
        }

        function getProviderBadge(provider) {
            const p = (provider || 'unknown').toLowerCase();
            let cls = 'provider-mock';
            if (p.includes('openai')) cls = 'provider-openai';
            else if (p.includes('gemini')) cls = 'provider-gemini';
            else if (p.includes('cache') || p.includes('redis')) cls = 'provider-cache';
            return `<span class="provider-badge ${cls}">${provider}</span>`;
        }

        // ═══════════ UPDATE METRICS ═══════════
        function updateMetrics(provider, latency, tokens, model, error, routePath, costEstimate) {
            metricsEmpty.style.display = 'none';
            metricsGrid.style.display = 'flex';

            if (error) {
                metricsGrid.innerHTML = `
                    <div class="metric-card" style="border-color:rgba(248,113,113,0.3);">
                        <span class="metric-label">Status</span>
                        <span class="metric-value" style="color:var(--error);">Failed</span>
                        <p style="font-size:0.8rem;color:var(--text-muted);margin-top:4px;">${error}</p>
                    </div>
                `;
                return;
            }

            const latClass = getLatencyClass(latency);
            
            // Build route visualization
            let routeHTML = '';
            if (routePath && routePath.length > 0) {
                const successStep = routePath.find(s => s.status === 'success');
                routeHTML = `
                    <div class="metric-card" style="grid-column: 1/-1;">
                        <span class="metric-label">🛣️ Route Path</span>
                        <div style="margin-top: 8px; font-size: 0.9rem;">
                            ${successStep ? `<div style="color: var(--success); font-weight: 600; margin-bottom: 8px;">✓ Resolved via ${successStep.provider.toUpperCase()}</div>` : ''}
                `;
                
                routePath.forEach((step, idx) => {
                    const statusColor = step.status === 'success' ? 'var(--success)' : 'var(--error)';
                    const statusIcon = step.status === 'success' ? '✓' : '✗';
                    const sourceLabel = step.source === 'cache' ? '(Cached)' : `(Attempt ${idx + 1})`;
                    routeHTML += `
                        <div style="padding: 6px; background: rgba(255,255,255,0.02); border-left: 2px solid ${statusColor}; margin-bottom: 4px;">
                            <div><strong>${step.provider.toUpperCase()}</strong> ${sourceLabel} <span style="color: ${statusColor};">${statusIcon}</span></div>
                            <div style="font-size: 0.8rem; color: var(--text-muted);">Req: ${step.requested_model} → Res: ${step.resolved_model || 'N/A'}</div>
                        </div>
                    `;
                });
                
                routeHTML += `</div></div>`;
            }
            
            // Build cost visualization
            let costHTML = '';
            if (costEstimate) {
                const formatCost = (val) => '$' + (val < 0.000001 ? '<0.000001' : val.toFixed(7));
                costHTML = `
                    <div class="metric-card" style="grid-column: 1/-1;">
                        <span class="metric-label">💰 Cost Estimate</span>
                        <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; margin-top: 8px; font-size: 0.9rem;">
                            <div>
                                <div style="color: var(--text-muted); font-size: 0.8rem;">OpenAI</div>
                                <div style="font-weight: 600;">${formatCost(costEstimate.openai_usd)}</div>
                            </div>
                            <div>
                                <div style="color: var(--text-muted); font-size: 0.8rem;">Gemini</div>
                                <div style="font-weight: 600;">${formatCost(costEstimate.gemini_usd)}</div>
                            </div>
                            <div>
                                <div style="color: var(--success); font-size: 0.8rem;">Used</div>
                                <div style="font-weight: 600; color: var(--success);">${formatCost(costEstimate.provider_used_usd)}</div>
                            </div>
                        </div>
                    </div>
                `;
            }

            metricsGrid.innerHTML = `
                <div class="metric-card">
                    <span class="metric-label">Resolved Provider</span>
                    ${getProviderBadge(provider)}
                </div>
                <div class="metric-card">
                    <span class="metric-label">Model</span>
                    <span class="metric-value" style="font-size:1rem;">${model || 'N/A'}</span>
                </div>
                <div class="metric-card">
                    <span class="metric-label">Roundtrip Latency</span>
                    <span class="metric-value ${latClass}">${latency.toLocaleString()} ms</span>
                </div>
                <div class="metric-card">
                    <span class="metric-label">Token Usage</span>
                    <span class="metric-value">${tokens}</span>
                </div>
                ${routeHTML}
                ${costHTML}
            `;
        }

        // ═══════════ UPDATE HISTORY ═══════════
        function addHistoryEntry(provider, latency, tokens, status, routePath, costEstimate) {
            const now = new Date();
            const time = now.toLocaleTimeString('en-US', { hour12: false, hour: '2-digit', minute: '2-digit', second: '2-digit' });
            const p = (provider || 'unknown').toLowerCase();

            let provClass = 'color:var(--mock-color)';
            if (p.includes('openai')) provClass = 'color:var(--openai-color)';
            else if (p.includes('gemini')) provClass = 'color:var(--gemini-color)';
            else if (p.includes('cache') || p.includes('redis')) provClass = 'color:var(--cache-color)';

            const latClass = getLatencyClass(latency);
            const statusIcon = status === 200 ? '✓' : '✗';
            const statusColor = status === 200 ? 'var(--success)' : 'var(--error)';

            // Build detailed history entry with expandable route/cost
            const entry = document.createElement('div');
            entry.className = 'history-item';
            
            const routeSummary = routePath && routePath.length > 0 
                ? `${routePath.length} step${routePath.length > 1 ? 's' : ''}`
                : 'N/A';
            const costSummary = costEstimate 
                ? `$${costEstimate.provider_used_usd.toFixed(7)}`
                : 'N/A';
            
            entry.innerHTML = `
                <div style="display: flex; justify-content: space-between; align-items: center; width: 100%; gap: 8px;">
                    <span class="history-time">${time}</span>
                    <span class="history-provider" style="${provClass}">${(provider || 'unknown').toUpperCase()}</span>
                    <span class="history-latency ${latClass}">${latency.toLocaleString()} ms</span>
                    <span class="history-tokens">${tokens} tok</span>
                    <span style="font-size: 0.8rem; color: var(--success);">📍 ${routeSummary}</span>
                    <span style="font-size: 0.8rem; color: var(--accent);">💰 ${costSummary}</span>
                </div>
            `;

            // Replace empty state or prepend
            if (historyList.querySelector('.history-empty')) {
                historyList.innerHTML = '';
            }
            historyList.prepend(entry);
            
            // Keep only last 20 entries
            const items = historyList.querySelectorAll('.history-item');
            if (items.length > 20) {
                items[items.length - 1].remove();
            }
        }

        // ═══════════ CLEAR CHAT ═══════════
        function clearChat() {
            chatBox.innerHTML = `
                <div class="message bot-message">
                    Chat cleared. Send a new message to continue testing.
                </div>
            `;
            chatHistory = [];
            sessionStats = { totalRequests: 0, totalLatency: 0, totalTokens: 0, cacheHits: 0, history: [] };

            document.getElementById('statRequests').textContent = '0';
            document.getElementById('statAvgLatency').textContent = '— ms';
            document.getElementById('statAvgLatency').className = 'stat-value';
            document.getElementById('statTotalTokens').textContent = '0';
            document.getElementById('statCacheHits').textContent = '0%';

            metricsGrid.style.display = 'none';
            metricsEmpty.style.display = 'flex';
            historyList.innerHTML = '<div class="history-empty">No requests yet</div>';
        }

        // ═══════════ SEND MESSAGE ═══════════
        async function sendMessage() {
            const content = messageInput.value.trim();
            const apiKey = apiKeyInput.value.trim();

            if (!content) return;
            if (!apiKey) {
                alert("Please enter your X-API-Key");
                apiKeyInput.focus();
                return;
            }

            // Disable UI
            messageInput.value = '';
            messageInput.disabled = true;
            sendBtn.disabled = true;

            // Show user message + loading
            appendMessage('user', content);
            chatHistory.push({ role: "user", content: content });
            loadingIndicator.style.display = 'block';
            chatBox.scrollTop = chatBox.scrollHeight;

            const startTime = performance.now();

            try {
                const response = await fetch('/chat', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-API-Key': apiKey
                    },
                    body: JSON.stringify({
                        messages: chatHistory,
                        model: "gpt-3.5-turbo"
                    })
                });

                const latency = Math.round(performance.now() - startTime);
                const data = await response.json();
                loadingIndicator.style.display = 'none';

                if (!response.ok) {
                    appendMessage('bot', `Error: ${data.detail || 'Unknown server error'}`, true);
                    updateMetrics(null, latency, 0, null, data.detail);
                    addHistoryEntry('error', latency, 0, response.status);
                    updateSessionStats(latency, 0, 'error');
                    chatHistory.pop();
                } else {
                    appendMessage('bot', data.content);
                    chatHistory.push({ role: "assistant", content: data.content });

                    const totalTokens = data.usage ? data.usage.total_tokens : 0;
                    
                    // Pass route_path and cost_estimate to updateMetrics
                    updateMetrics(
                        data.provider, 
                        latency, 
                        totalTokens, 
                        data.model,
                        null,
                        data.route_path,
                        data.cost_estimate
                    );
                    
                    // Pass route_path and cost_estimate to addHistoryEntry
                    addHistoryEntry(
                        data.provider, 
                        latency, 
                        totalTokens, 
                        200,
                        data.route_path,
                        data.cost_estimate
                    );
                    
                    updateSessionStats(latency, totalTokens, data.provider);
                }

            } catch (err) {
                loadingIndicator.style.display = 'none';
                appendMessage('bot', `Connection Error: ${err.message}`, true);
                updateMetrics(null, 0, 0, null, err.message);
                chatHistory.pop();
            }

            // Re-enable UI
            messageInput.disabled = false;
            sendBtn.disabled = false;
            messageInput.focus();
        }
    </script>
</body>
</html>
